IMAGE_PROVIDER=auto1111
SD_API_URL=http://127.0.0.1:7860
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-schnell
REPLICATE_OUTPUT_FORMAT=jpg
META_ACCESS_TOKEN=
FB_PAGE_ID=
IG_BUSINESS_ID=
# Used to prefer locally hosted image URLs for Meta posting.
PREFER_LOCAL_PUBLIC_IMAGE_URL=true
# Required when PREFER_LOCAL_PUBLIC_IMAGE_URL=true (recommended for Meta compatibility).
# If using site root, generated/<filename> is appended automatically.
# Example site root: http://YOUR_PUBLIC_HOST:8080/images
# Example generated dir base: http://YOUR_PUBLIC_HOST:8080/images/generated/
IMG_PUBLIC_URL_BASE=http://YOUR_PUBLIC_HOST:PORT/images/generated
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
META_GRAPH_VERSION=v20.0
POST_INTERVAL_HOURS=4
RANDOMIZE_INTERVAL_MINUTES=0
LOG_PATH=logs/xeanvi_social_bot.log
DRY_RUN=false
MANUAL_REVIEW_MODE=false
MAX_GENERATION_ATTEMPTS=3
OPENAI_API_KEY=
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1350
SD_MODEL=dreamshaper_8.safetensors
